<% const title = team.name; %>
<%- include('layout') %>

<a href="/admin" class="back-link">&larr; All Teams</a>

<div class="team-header">
  <% if (team.logo_path) { %>
    <img src="<%= team.logo_path %>" alt="<%= team.name %> logo" class="team-logo">
  <% } %>
  <h1><%= team.name %></h1>
  <p class="muted">Public URL: <a href="/team/<%= team.slug %>" target="_blank">/team/<%= team.slug %></a></p>
</div>

<div class="card">
  <h2>Add Game</h2>
  <form method="POST" action="/admin/teams/<%= team.slug %>/games" class="game-form">
    <div class="form-row">
      <div class="form-group">
        <label for="game_date">Date</label>
        <input type="date" id="game_date" name="game_date" required>
      </div>
      <div class="form-group">
        <label for="game_time">Time</label>
        <select id="game_time" name="game_time" required>
          <option value="">Select time</option>
          <% for (let h = 6; h <= 21; h++) { const val = String(h).padStart(2,'0') + ':00'; const hour = h > 12 ? h - 12 : (h === 0 ? 12 : h); const ampm = h >= 12 ? 'PM' : 'AM'; %>
            <option value="<%= val %>"><%= hour %> <%= ampm %></option>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label for="home_away">Home/Away</label>
        <select id="home_away" name="home_away" required>
          <option value="home">Home</option>
          <option value="away">Away</option>
        </select>
      </div>
      <div class="form-group">
        <label for="field_number">Field #</label>
        <input type="text" id="field_number" name="field_number" placeholder="e.g. 3">
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Add Game</button>
  </form>
</div>

<h2>Games</h2>
<% if (games.length === 0) { %>
  <p class="muted">No games yet. Add one above!</p>
<% } else { %>
  <table class="games-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Time</th>
        <th>Home/Away</th>
        <th>Field</th>
        <th>Signed Up</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% for (const game of games) { %>
        <tr>
          <td><%= game.game_date %></td>
          <td><%= game.game_time %></td>
          <td><%= game.home_away === 'home' ? 'Home' : 'Away' %></td>
          <td><%= game.field_number || '—' %></td>
          <td><%= game.parent_name || '—' %></td>
          <td style="white-space:nowrap">
            <button type="button" class="btn btn-small btn-outline" onclick="document.getElementById('edit-<%= game.id %>').toggleAttribute('hidden')">Edit</button>
            <form method="POST" action="/admin/teams/<%= team.slug %>/games/<%= game.id %>/delete" style="display:inline">
              <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Delete this game?')">Delete</button>
            </form>
          </td>
        </tr>
        <tr id="edit-<%= game.id %>" hidden>
          <td colspan="6">
            <form method="POST" action="/admin/teams/<%= team.slug %>/games/<%= game.id %>/edit" class="game-form" style="padding:0.5rem 0">
              <div class="form-row">
                <div class="form-group">
                  <label>Date</label>
                  <input type="date" name="game_date" value="<%= game.game_date %>" required>
                </div>
                <div class="form-group">
                  <label>Time</label>
                  <select name="game_time" required>
                    <% for (let h = 6; h <= 21; h++) { const val = String(h).padStart(2,'0') + ':00'; const hour = h > 12 ? h - 12 : (h === 0 ? 12 : h); const ampm = h >= 12 ? 'PM' : 'AM'; %>
                      <option value="<%= val %>" <%= game.game_time === val ? 'selected' : '' %>><%= hour %> <%= ampm %></option>
                    <% } %>
                  </select>
                </div>
                <div class="form-group">
                  <label>Home/Away</label>
                  <select name="home_away" required>
                    <option value="home" <%= game.home_away === 'home' ? 'selected' : '' %>>Home</option>
                    <option value="away" <%= game.home_away === 'away' ? 'selected' : '' %>>Away</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Field #</label>
                  <input type="text" name="field_number" value="<%= game.field_number || '' %>">
                </div>
              </div>
              <button type="submit" class="btn btn-primary">Save</button>
            </form>
            <div style="border-top:1px solid #eee;margin-top:0.75rem;padding-top:0.75rem">
              <% if (game.parent_name) { %>
                <div id="signup-display-<%= game.signup_id %>">
                  <div class="form-row" style="align-items:flex-end">
                    <div class="form-group">
                      <label>Signed Up</label>
                      <input type="text" value="<%= game.parent_name %>" disabled>
                    </div>
                    <div class="form-group" style="display:flex;gap:0.5rem;padding-bottom:0.75rem">
                      <button type="button" class="btn btn-outline" onclick="document.getElementById('signup-display-<%= game.signup_id %>').hidden=true; document.getElementById('signup-edit-<%= game.signup_id %>').hidden=false">Edit</button>
                      <form method="POST" action="/admin/teams/<%= team.slug %>/signups/<%= game.signup_id %>/delete">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Remove signup?')">Remove</button>
                      </form>
                    </div>
                  </div>
                </div>
                <form method="POST" action="/admin/teams/<%= team.slug %>/signups/<%= game.signup_id %>/edit" id="signup-edit-<%= game.signup_id %>" hidden>
                  <div class="form-row" style="align-items:flex-end">
                    <div class="form-group">
                      <label>Signed Up</label>
                      <input type="text" name="parent_name" value="<%= game.parent_name %>">
                    </div>
                    <div class="form-group" style="padding-bottom:0.75rem">
                      <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                  </div>
                </form>
              <% } else { %>
                <div class="form-row">
                  <div class="form-group">
                    <label>Signed Up</label>
                    <input type="text" value="—" disabled>
                  </div>
                </div>
              <% } %>
            </div>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<div class="card">
  <h2>Team Details</h2>
  <form method="POST" action="/admin/teams/<%= team.slug %>/edit">
    <div class="form-group">
      <label for="team_name">Team Name</label>
      <input type="text" id="team_name" name="name" value="<%= team.name %>" required>
    </div>
    <div class="form-group">
      <label for="team_description">Description</label>
      <input type="text" id="team_description" name="description" value="<%= team.description || '' %>" placeholder="e.g. U10 boys soccer, Fall 2026">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="team_grade">Grade</label>
        <input type="text" id="team_grade" name="grade" value="<%= team.grade || '' %>" placeholder="e.g. 3rd">
      </div>
      <div class="form-group">
        <label for="team_season">Season</label>
        <input type="text" id="team_season" name="season" value="<%= team.season || '' %>" placeholder="e.g. Spring 2026">
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
</div>

<div class="card">
  <h2>Upload Logo</h2>
  <form method="POST" action="/admin/teams/<%= team.slug %>/logo" enctype="multipart/form-data" class="inline-form">
    <input type="file" name="logo" accept="image/*" required>
    <button type="submit" class="btn btn-primary">Upload</button>
  </form>
</div>

<%- include('footer') %>
