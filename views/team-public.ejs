<% const title = team.name; %>
<%- include('layout') %>

<div class="public-team">
  <% if (team.logo_path) { %>
    <div class="logo-center">
      <img src="<%= team.logo_path %>" alt="<%= team.name %> logo" class="team-logo-large">
    </div>
  <% } %>
  <h1 class="text-center"><%= team.name %></h1>
  <% if (team.grade || team.season) { %>
    <div class="team-meta">
      <% if (team.grade) { %><span class="badge badge-field"><%= team.grade %></span><% } %>
      <% if (team.season) { %><span class="badge badge-home"><%= team.season %></span><% } %>
    </div>
  <% } %>
  <% if (team.description) { %>
    <p class="team-description"><%= team.description %></p>
  <% } %>

  <% if (success) { %>
    <div class="success-msg">Thanks for signing up to bring snacks!</div>
  <% } %>

  <% if (games.length === 0) { %>
    <p class="muted text-center">No games scheduled yet. Check back soon!</p>
  <% } else { %>
    <% for (const game of games) { %>
      <div class="card game-card <%= game.signups.length > 0 ? 'game-filled' : 'game-open' %>">
        <div class="game-info">
          <h3>
            <%= (() => { const [y,m,d] = game.game_date.split('-'); const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; return months[parseInt(m)-1] + ' ' + parseInt(d); })() %> at <%= (() => { const [h,m] = game.game_time.split(':'); const hr = parseInt(h); return (hr > 12 ? hr - 12 : (hr === 0 ? 12 : hr)) + (m !== '00' ? ':' + m : '') + (hr >= 12 ? 'PM' : 'AM'); })() %>
          </h3>
          <div class="game-badges">
            <% if (game.field_number) { %>
              <span class="badge badge-field"><svg width="14" height="14" viewBox="0 0 24 24" fill="white" stroke="#155724" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="12" y1="4" x2="12" y2="20"/><circle cx="12" cy="12" r="3"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>Field <%= game.field_number %></span>
            <% } %>
            <span class="badge badge-<%= game.home_away %>"><svg width="14" height="14" viewBox="0 0 24 24" fill="<%= game.home_away === 'home' ? 'white' : '#dc3545' %>" stroke="<%= game.home_away === 'home' ? '#6c757d' : '#a71d2a' %>" stroke-width="1.5"><path d="M6 2L1 7v3h4v12h14V10h4V7l-5-5-4 3h-4L6 2z"/></svg><%= game.home_away === 'home' ? 'Home' : 'Away' %></span>
          </div>
        </div>

        <% if (game.signups.length > 0) { %>
          <div class="signups-list">
            <h4>Signed up: <%= game.signups[0].parent_name %></h4>
            <% const su = game.signups[0]; %>
            <% if (su.phone_number && su.carrier) { %>
              <p style="font-size:0.85rem;color:#6c757d;margin-top:0.25rem">Text reminder on</p>
            <% } else { %>
              <button type="button" class="btn btn-small btn-outline" style="margin-top:0.5rem" onclick="document.getElementById('phone-edit-<%= su.id %>').toggleAttribute('hidden')">
                Add Phone for Reminders
              </button>
              <form method="POST" action="/team/<%= team.slug %>/signup/<%= su.id %>/phone" id="phone-edit-<%= su.id %>" hidden style="margin-top:0.5rem">
                <div class="phone-row">
                  <div class="form-group">
                    <input type="tel" name="phone_number" placeholder="(555) 123-4567">
                  </div>
                  <div class="form-group">
                    <select name="carrier">
                      <option value="">Carrier</option>
                      <option value="att">AT&T</option>
                      <option value="tmobile">T-Mobile</option>
                      <option value="verizon">Verizon</option>
                      <option value="cricket">Cricket</option>
                      <option value="metro">Metro by T-Mobile</option>
                      <option value="uscellular">US Cellular</option>
                      <option value="boost">Boost Mobile</option>
                      <option value="mint">Mint Mobile</option>
                    </select>
                  </div>
                  <button type="submit" class="btn btn-small btn-primary">Save</button>
                </div>
              </form>
            <% } %>
          </div>
        <% } else { %>
          <form method="POST" action="/team/<%= team.slug %>/signup" class="signup-form">
            <input type="hidden" name="game_id" value="<%= game.id %>">
            <div class="form-row">
              <input type="text" name="parent_name" placeholder="Your name" required>
              <button type="submit" class="btn btn-primary">Sign Up</button>
            </div>
            <div class="phone-row">
              <div class="form-group">
                <input type="tel" name="phone_number" placeholder="Phone (optional)">
              </div>
              <div class="form-group">
                <select name="carrier">
                  <option value="">Carrier</option>
                  <option value="att">AT&T</option>
                  <option value="tmobile">T-Mobile</option>
                  <option value="verizon">Verizon</option>
                  <option value="cricket">Cricket</option>
                  <option value="metro">Metro by T-Mobile</option>
                  <option value="uscellular">US Cellular</option>
                  <option value="boost">Boost Mobile</option>
                  <option value="mint">Mint Mobile</option>
                </select>
              </div>
            </div>
          </form>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('footer') %>
