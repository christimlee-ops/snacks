<% const title = team.name; %>
<%- include('layout') %>

<div class="public-team">
  <% if (team.logo_path) { %>
    <div class="logo-center">
      <img src="<%= team.logo_path %>" alt="<%= team.name %> logo" class="team-logo-large">
    </div>
  <% } %>
  <h1 class="text-center"><%= team.name %></h1>
  <% if (team.grade || team.season) { %>
    <div class="team-meta">
      <% if (team.grade) { %><span class="badge badge-field"><%= team.grade %></span><% } %>
      <% if (team.season) { %><span class="badge badge-home"><%= team.season %></span><% } %>
    </div>
  <% } %>
  <% if (team.description) { %>
    <div class="team-description"><%= team.description %></div>
  <% } %>

  <% if (success) { %>
    <div class="success-msg">Thanks for signing up to bring snacks!</div>
  <% } %>

  <% if (games.length === 0) { %>
    <p class="muted text-center">No games scheduled yet. Check back soon!</p>
  <% } else { %>
    <button class="past-games-toggle" id="pastGamesToggle">Show Past Games</button>
    <% for (const game of games) { %>
      <div class="card game-card <%= game.signups.length > 0 ? 'game-filled' : 'game-open' %>" id="game-<%= game.id %>" data-game-date="<%= game.game_date %>">
        <div class="game-info">
          <h3>
            <%= (() => { const [y,m,d] = game.game_date.split('-'); const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; return months[parseInt(m)-1] + ' ' + parseInt(d); })() %>
            <% if (game.game_result) { %>
              <span class="badge badge-result-<%= game.game_result %>"><%= game.game_result.charAt(0).toUpperCase() + game.game_result.slice(1) %></span>
            <% } %>
          </h3>
          <div class="game-badges">
            <span class="badge badge-time"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#856404" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><%= (() => { const [h,m] = game.game_time.split(':'); const hr = parseInt(h); return (hr > 12 ? hr - 12 : (hr === 0 ? 12 : hr)) + (m !== '00' ? ':' + m : '') + (hr >= 12 ? 'PM' : 'AM'); })() %></span>
            <% if (game.field_number) { %>
              <span class="badge badge-field"><svg width="14" height="14" viewBox="0 0 24 24" fill="white" stroke="#155724" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="12" y1="4" x2="12" y2="20"/><circle cx="12" cy="12" r="3"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>Field <%= game.field_number %></span>
            <% } %>
            <span class="badge badge-<%= game.home_away %>"><svg width="14" height="14" viewBox="0 0 24 24" fill="<%= game.home_away === 'home' ? 'white' : '#dc3545' %>" stroke="<%= game.home_away === 'home' ? '#6c757d' : '#a71d2a' %>" stroke-width="1.5"><path d="M6 2L1 7v3h4v12h14V10h4V7l-5-5-4 3h-4L6 2z"/></svg><%= game.home_away === 'home' ? 'Home' : 'Away' %></span>
          </div>
        </div>

        <div class="game-card-body">
        <% if (game.signups.length > 0) { %>
          <div class="signups-list">
            <h4>Snack Signup: <%= game.signups[0].parent_name %></h4>
          </div>
        <% } else { %>
          <form method="POST" action="/team/<%= team.slug %>/signup" class="signup-form">
            <input type="hidden" name="game_id" value="<%= game.id %>">
            <div class="form-row">
              <input type="text" name="parent_name" placeholder="Your name" required>
              <button type="submit" class="btn btn-primary">Snack Sign Up</button>
            </div>
          </form>
        <% } %>

        <% if (players.length > 0) { %>
          <% let attending = 0; %>
          <% for (const p of players) { if (rsvpSet.has(game.id + '-' + p.id)) attending++; } %>
          <div class="rsvp-section">
            <h4>Who's Coming? <span class="rsvp-count"><%= attending %> / <%= players.length %></span></h4>
            <div class="rsvp-list">
              <% for (const player of players) { %>
                <% const isRsvped = rsvpSet.has(game.id + '-' + player.id); %>
                <form method="POST" action="/team/<%= team.slug %>/rsvp" style="display:inline">
                  <input type="hidden" name="game_id" value="<%= game.id %>">
                  <input type="hidden" name="player_id" value="<%= player.id %>">
                  <button type="submit" class="rsvp-toggle <%= isRsvped ? 'rsvp-yes' : 'rsvp-no' %>"><%= isRsvped ? '✓ ' : '' %><%= player.player_name %></button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<script>
(function() {
  var today = new Date();
  today.setHours(0, 0, 0, 0);
  var yesterday = new Date(today);
  yesterday.setDate(yesterday.getDate() - 1);
  var hasPast = false;
  document.querySelectorAll('.game-card[data-game-date]').forEach(function(card) {
    var parts = card.getAttribute('data-game-date').split('-');
    var gameDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
    if (gameDate < yesterday) {
      hasPast = true;
      card.classList.add('past-game');
      card.addEventListener('click', function() {
        card.classList.toggle('expanded');
      });
    }
  });
  var toggle = document.getElementById('pastGamesToggle');
  if (hasPast) {
    toggle.classList.add('has-past-games');
    toggle.addEventListener('click', function() {
      var container = document.querySelector('.public-team');
      var showing = container.classList.toggle('past-games-visible');
      toggle.textContent = showing ? 'Hide Past Games' : 'Show Past Games';
    });
  }
})();
</script>

<% if (team.banner_color) { %>
<script>document.querySelector('.navbar').style.background = '<%= team.banner_color %>';</script>
<% } else if (team.logo_path) { %>
<script>
(function() {
  var img = document.querySelector('.team-logo-large');
  if (!img) return;
  function applyColor() {
    var canvas = document.createElement('canvas');
    var ctx = canvas.getContext('2d');
    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);
    var data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
    var counts = {};
    var maxCount = 0;
    var dominant = [45, 106, 79];
    for (var i = 0; i < data.length; i += 16) {
      var r = data[i], g = data[i+1], b = data[i+2], a = data[i+3];
      if (a < 128) continue;
      if (r > 220 && g > 220 && b > 220) continue;
      if (r < 30 && g < 30 && b < 30) continue;
      var qr = Math.round(r / 32) * 32;
      var qg = Math.round(g / 32) * 32;
      var qb = Math.round(b / 32) * 32;
      var key = qr + ',' + qg + ',' + qb;
      counts[key] = (counts[key] || 0) + 1;
      if (counts[key] > maxCount) {
        maxCount = counts[key];
        dominant = [qr, qg, qb];
      }
    }
    var dr = Math.max(0, Math.round(dominant[0] * 0.7));
    var dg = Math.max(0, Math.round(dominant[1] * 0.7));
    var db = Math.max(0, Math.round(dominant[2] * 0.7));
    document.querySelector('.navbar').style.background = 'rgb(' + dr + ',' + dg + ',' + db + ')';
  }
  if (img.complete) applyColor();
  else img.addEventListener('load', applyColor);
})();
</script>
<% } %>

<%- include('footer') %>
